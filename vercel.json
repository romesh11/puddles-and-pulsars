{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/game", "destination": "/game.html" },
    { "source": "/book", "destination": "/book/index.html" },
    { "source": "/book/entry-1", "destination": "/book/entry-1/index.html" }
  ],
  "headers": [
    {
      "source": "/game.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}
