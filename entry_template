      font-size: clamp(1.75rem, 5vw, 2.2rem);
      font-weight: 400;
      font-style: italic;
      color: var(--text-primary);
      margin: 0 0 clamp(1.75rem, 4vw, 2.5rem);
      line-height: 1.15;
