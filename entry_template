    .entry-body {
      font-size: clamp(0.92rem, 2vw, 1rem);
      color: var(--text-body);
      line-height: 2;
    }

    .entry-body p { margin: 0 0 1.5rem; }
    .entry-body p:last-child { margin: 0; }

    .entry-body p.beat {
      color: #cbd5e1;
      font-style: italic;
    }

    .entry-divider {
      margin: clamp(2rem, 5vw, 3rem) 0;
      height: 0;
    }

    .entry-nav { display: flex; justify-content: flex-end; }

    .entry-next {
      font-size: 0.72rem;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--accent);
      text-decoration: none;
      transition: color 0.2s;
