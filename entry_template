      color: var(--text-primary);
      text-decoration: none;
      letter-spacing: 0.02em;
    }
    .logo span { color: var(--accent); }

    .back-link {
      font-size: 0.78rem;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: var(--accent); }

    .entry-wrap {
      position: relative;
      z-index: 10;
      max-width: 620px;
      margin: 0 auto;
      padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 5vw, 2rem) clamp(3rem, 8vw, 5rem);
      flex: 1;
